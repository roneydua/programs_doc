{
  "python.analysis.extraPaths": ["${workspaceFolder}/"],
  "cSpell.words": [
    "ARED",
    "ddrm",
    "dfdq",
    "euler",
    "gpib",
    "iloc",
    "mult",
    "popen",
    "variacao"
  ],
  "python.defaultInterpreterPath": "./.venv/bin/python3.12",
  "path-intellisense.absolutePathTo": "./",
  "jupyter.notebookFileRoot": "${workspaceFolder}/",
  "jupyter.interactiveWindow.codeLens.enable": true,
  "cSpell.ignoreWords": ["lawofs"],
  
  "terminal.integrated.env.linux": {
    "PYTHONPATH": "${workspaceFolder}"
  },
  "python.envFile": "${workspaceFolder}/python/.venv",
  "pylint.args": [
    "--disable=C0116",
    "--disable=C0206",
    "--disable=W0105",
    "--disable=W0612",
    "--disable=W0611",
    "--disable=E1136",
    "--disable=C0301"
  ]
}
