{
  "python.analysis.extraPaths": ["${workspaceFolder}/"],
  "cSpell.words": [
    "ARED",
    "ddrm",
    "dfdq",
    "euler",
    "gpib",
    "iloc",
    "mult",
    "popen",
    "variacao"
  ],
  "python.defaultInterpreterPath": "python/.venv/bin/python",
  "path-intellisense.absolutePathTo": "./",
  "jupyter.notebookFileRoot": "${workspaceFolder}/",
  "jupyter.interactiveWindow.codeLens.enable": true,
  "cSpell.ignoreWords": ["lawofs"],
  "ipython.StartupCommands": ["%load_ext autoreload", "%autoreload 2"],

  "terminal.integrated.env.linux": {
    "PATH": "${workspaceFolder}/python/.venv/bin:${env:PATH}",
    "PYTHONPATH": "${workspaceFolder}"
  },
  "python.envFile": "${workspaceFolder}/.env",
  "pylint.args": [
    "--disable=C0116",
    "--disable=C0206",
    "--disable=W0105",
    "--disable=W0612",
    "--disable=W0611",
    "--disable=E1136",
    "--disable=C0301"
  ]
}
